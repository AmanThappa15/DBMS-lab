SELECT C.S_id -- Nested Not EXIST
FROM Catalog C
WHERE NOT EXISTS(SELECT P.P_id
				FROM part P 
                WHERE NOT EXISTS(SELECT P.P_id
                FROM Catalog C1
                WHERE C1.S_id=C.S_id
                AND C1.P_id=C.P_id)
                );
	SELECT C.S_id
    FROM Catalog C 
    WHERE NOT EXISTS(SELECT P_id
					FROM part 
                    EXCEPT
                    SELECT P_id
                    FROM Catalog C1
                    WHERE C1.S_id=C.S_id
					);
	
	
